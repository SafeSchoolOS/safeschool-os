# =============================================================================
# SafeSchoolOS EdgeRuntime Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# --- Runtime Mode ---
# STANDALONE = local only, no cloud sync (default if no activation key)
# EDGE = on-site device syncing to cloud
# CLOUD = cloud backend (Railway deployment)
OPERATING_MODE=EDGE

# --- Activation Key ---
# Leave blank to run in standalone/demo mode (no cloud sync)
# Get a key from your SafeSchoolOS cloud dashboard or generate with tools/keygen
EDGERUNTIME_ACTIVATION_KEY=

# --- HMAC Secret ---
# Required for activation key verification
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EDGERUNTIME_HMAC_SECRET=

# --- Cloud Sync ---
# Required for EDGE mode. The cloud sync key authenticates edge-to-cloud communication.
CLOUD_SYNC_KEY=

# --- Site Identity ---
# Unique identifier for this edge device
EDGERUNTIME_SITE_ID=site-001
EDGERUNTIME_ORG_ID=my-org

# --- API Server ---
EDGERUNTIME_API_PORT=8470

# --- JWT Authentication ---
# Secret for signing dashboard login tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Dashboard Admin ---
# Default admin credentials for the built-in dashboard
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=

# --- Data Directory ---
# Where EdgeRuntime stores sync queue, config, and local data
EDGERUNTIME_DATA_DIR=./data

# --- Access Control Integration ---
# Vendor: lenel-onguard, genetec, brivo, verkada, s2-netbox, assa-abloy, sicunet
ACCESS_CONTROL_VENDOR=
ACCESS_CONTROL_HOST=
ACCESS_CONTROL_PORT=
ACCESS_CONTROL_USERNAME=
ACCESS_CONTROL_PASSWORD=

# --- Camera / VMS Integration ---
# Vendor: milestone-xprotect, genetec, avigilon, verkada, onvif
CAMERA_VENDOR=
CAMERA_HOST=
CAMERA_PORT=80
CAMERA_USERNAME=
CAMERA_PASSWORD=

# --- 911 Dispatch ---
# Adapter: rapidsoc, rave, sip, console
DISPATCH_ADAPTER=

# --- Notifications ---
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Connector Polling ---
# How often connectors poll vendor APIs for events (ms)
CONNECTOR_POLL_INTERVAL=5000

# --- Sync Intervals ---
SYNC_INTERVAL_MS=30000
HEALTH_CHECK_INTERVAL_MS=60000

# --- Federation (cross-product event sharing) ---
# Enable if multiple edge devices on the same network
FEDERATION_ENABLED=false
# FEDERATION_PEERS='[{"product":"safeschool","url":"http://192.168.1.101:8470","siteId":"site-002"}]'

# --- TLS ---
# Pin the cloud server TLS certificate fingerprint (optional, extra security)
# CLOUD_TLS_FINGERPRINT=sha256/AAAA...

# --- Demo Mode ---
# Enable /demo URL for no-login read-only dashboard access
# Great for product pages and sales demos
DEMO_MODE=false
DEMO_ORG_ID=demo
