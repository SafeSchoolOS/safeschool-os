# SafeSchoolOS Appliance - Caddy Reverse Proxy
# Auto-HTTPS with self-signed certs for local network

{
	auto_https disable_redirects
	local_certs
}

# Dashboard (main UI) - HTTPS on 443
:443 {
	tls internal {
		on_demand
	}
	# Unified dashboard served by EdgeRuntime
	handle /dashboard* {
		reverse_proxy edgeruntime:8470
	}
	# API routes through EdgeRuntime (fleet, sync, data, etc.)
	handle /api/* {
		reverse_proxy edgeruntime:8470
	}
	# Kiosk mode
	handle /kiosk* {
		reverse_proxy edgeruntime:8470
	}
	# Default: redirect to unified dashboard
	handle {
		redir / /dashboard 302
	}
}

# Kiosk (visitor check-in) - HTTPS on 8443
:8443 {
	tls internal {
		on_demand
	}
	reverse_proxy kiosk:3000
}

# API - HTTPS on 3443
:3443 {
	tls internal {
		on_demand
	}
	reverse_proxy api:3000
}

# EdgeRuntime - HTTP on 80
:80 {
	handle /health {
		reverse_proxy edgeruntime:8470
	}
	handle /ready {
		reverse_proxy edgeruntime:8470
	}
	handle /modules {
		reverse_proxy edgeruntime:8470
	}
	handle /setup* {
		reverse_proxy edgeruntime:8470
	}
	handle /api/* {
		reverse_proxy edgeruntime:8470
	}
	handle /dashboard* {
		reverse_proxy edgeruntime:8470
	}
	handle {
		redir / /dashboard 302
	}
}
