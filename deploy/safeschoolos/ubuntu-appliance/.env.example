# SafeSchoolOS Ubuntu Appliance Configuration
# Copy to .env and fill in values before first boot

# ─── Required ──────────────────────────────────────────────────────────
SITE_ID=00000000-0000-4000-a000-000000000001
SITE_NAME=Lincoln Elementary School
ORG_NAME=Newark Public Schools

# EdgeRuntime activation key (generate with: edgeruntime-keygen --products safeschool --tier starter --proxy safeschool)
EDGERUNTIME_ACTIVATION_KEY=XXXX-XXXX-XXXX-XXXX

# ─── Security (auto-generated on first boot if blank) ─────────────────
DB_PASSWORD=
JWT_SECRET=
SEED_ADMIN_PASSWORD=safeschool123

# ─── Cloud Sync ───────────────────────────────────────────────────────
# Cloud sync URL is auto-resolved from the activation key (no manual config needed)
CLOUD_SYNC_KEY=

# ─── Adapters ─────────────────────────────────────────────────────────
AUTH_PROVIDER=dev
DISPATCH_ADAPTER=console
ACCESS_CONTROL_ADAPTER=mock
NOTIFICATION_ADAPTER=console

# ─── Optional Integrations ────────────────────────────────────────────
# Milestone XProtect VMS
# MILESTONE_URL=https://milestone-server:443
# MILESTONE_USERNAME=
# MILESTONE_PASSWORD=
# MILESTONE_VERIFY_SSL=true

# Twilio (SMS/voice notifications)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# SendGrid (email notifications)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# ─── Auto-update ──────────────────────────────────────────────────────
WATCHTOWER_POLL_INTERVAL=3600
